# Supported values: windows, macos
APP_RUNTIME=macos

FRONTEND_PORT=4321
BACKEND_PORT=8081
DB_PORT=9001

POSTGRES_DB=economy_dict
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

LOCAL_SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:9001/economy_dict
DOCKER_SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/economy_dict
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

LOCAL_LOG_PATH=backend/logs
LOCAL_CHAT_STORAGE_PATH=backend/chats
CONTAINER_LOG_PATH=/app/backend/logs
CONTAINER_CHAT_STORAGE_PATH=/app/backend/chats

APP_JWT_SECRET=CHANGE_ME_JWT_SECRET_32_BYTES_MINIMUM_1234567890
APP_JWT_EXPIRATION_MS=86400000

OPENAI_API_BASE_URL=https://api.openai.com
OPENAI_API_KEY=REPLACE_ME
OPENAI_API_MODEL=gpt-4o-mini

VITE_API_TARGET=http://localhost:8081
